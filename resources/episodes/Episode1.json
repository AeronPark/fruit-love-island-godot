      "nodeType": "Dialogue",
      "backgroundId": "villa_path",
      "characters": [],
      "speakerId": "",
      "dialogueText": "You walk down the beautiful stone path toward the villa. The tropical flowers smell incredible, and you can hear laughter in the distance...",
      "nextNodeId": "arrival_2"
