      ],
      "speakerId": "peach",
      "speakerEmotion": "excited",
      "dialogueText": "Hello and welcome to FRUIT LOVE ISLAND!  I'm Penny the Peach, your host for this juicy season of love!",
      "nextNodeId": "intro_2"
    },
    {
      "nodeId": "intro_2",
      "nodeType": "Dialogue",
      "backgroundId": "villa_exterior",
      "characters": [
        {"characterId": "peach", "position": "Center", "emotion": "happy", "isHighlighted": true}
      ],
      "speakerId": "peach",
      "speakerEmotion": "happy",
      "dialogueText": "This season, eight single fruits have come to this tropical paradise looking for one thing... LOVE! ",
      "nextNodeId": "intro_3"
    },
    {
      "nodeId": "intro_3",
      "nodeType": "Dialogue",
      "backgroundId": "villa_exterior",
      "characters": [
        {"characterId": "peach", "position": "Center", "emotion": "mischievous", "isHighlighted": true}
      ],
      "speakerId": "peach",
      "speakerEmotion": "mischievous",
      "dialogueText": "But here's the twist... YOU are our newest islander! And trust me, your arrival is about to shake things up! ",
      "nextNodeId": "intro_4"
    },
    {
      "nodeId": "intro_4",
      "nodeType": "Dialogue",
      "backgroundId": "villa_exterior",
      "characters": [
        {"characterId": "peach", "position": "Center", "emotion": "serious", "isHighlighted": true}
      ],
      "speakerId": "peach",
      "speakerEmotion": "serious",
      "dialogueText": "The rules are simple: couple up, stay together, and don't get dumped. At the end of the summer, ONE couple will win the grand prize!",
      "nextNodeId": "intro_5"
    },
    {
      "nodeId": "intro_5",
      "nodeType": "Dialogue",
      "backgroundId": "villa_exterior",
      "characters": [
        {"characterId": "peach", "position": "Center", "emotion": "wink", "isHighlighted": true}
      ],
      "speakerId": "peach",
      "speakerEmotion": "wink",
      "dialogueText": "But remember... in this game, your choices MATTER. Every decision shapes your journey. So choose wisely! ",
      "nextNodeId": "intro_6"
    },
    {
      "nodeId": "intro_6",
      "nodeType": "Dialogue",
      "backgroundId": "villa_exterior",
      "characters": [
        {"characterId": "peach", "position": "Center", "emotion": "excited", "isHighlighted": true}
      ],
      "speakerId": "peach",
      "speakerEmotion": "excited",
      "dialogueText": "Now then... let's get you inside and meet some of your fellow islanders! Good luck, sweetie! ",
      "nextNodeId": "arrival_1"
    },
